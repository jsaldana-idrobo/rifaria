---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PublicHeader from "@/components/PublicHeader.astro";
import PublicFooter from "@/components/PublicFooter.astro";
import { AdminPanel } from "@/components/AdminPanel";
---

<BaseLayout
  title="Rifaria Admin"
  description="Panel administrativo de Rifaria para gestionar ventas, pagos y rifas."
>
  <meta slot="head" name="robots" content="noindex, nofollow, noarchive" />

  <PublicHeader admin ctaHref="/" ctaLabel="Ver landing" />

  <main class="admin-shell container">
    <section class="admin-hero glass-card">
      <div>
        <p class="section-kicker">Backoffice de operacion</p>
        <h1 class="brand-title">Control operativo de Rifaria</h1>
        <p class="section-copy">
          Acceso seguro para el equipo, tablero de ventas y lectura de estados
          con el mismo estilo que el sitio publico.
        </p>
      </div>

      <div class="admin-highlights">
        <article class="admin-highlight">
          <strong>Ventas</strong>
          <span>Lectura rapida del avance de la rifa activa.</span>
        </article>
        <article class="admin-highlight">
          <strong>Pagos</strong>
          <span>Resumen de estados para detectar friccion o retrasos.</span>
        </article>
        <article class="admin-highlight">
          <strong>Equipo</strong>
          <span
            >Ingreso centralizado con continuidad visual en todo el producto.</span
          >
        </article>
      </div>
    </section>

    <AdminPanel client:load />
  </main>

  <PublicFooter />
</BaseLayout>
