---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PublicHeader from "@/components/PublicHeader.astro";
import PublicFooter from "@/components/PublicFooter.astro";
import { fetchActiveRaffle } from "@/lib/api";
import { PurchaseWidget } from "@/components/PurchaseWidget";

const raffle = await fetchActiveRaffle();
const featuredPrize =
  raffle.featuredPrize ??
  raffle.upcomingPrizeDraws[0] ??
  raffle.completedPrizeDraws[0] ??
  null;
const primaryPrize = featuredPrize?.displayValue ?? raffle.prizeName;
const primaryImage = featuredPrize?.imageUrl ?? raffle.prizeImageUrl;
const primaryDrawAt = featuredPrize?.drawAt ?? raffle.drawAt;
const primaryDrawSource = featuredPrize?.drawSource ?? raffle.drawSource;
const remainingTickets = Math.max(raffle.totalTickets - raffle.soldTickets, 0);
const soldProgress =
  raffle.totalTickets > 0
    ? Math.round((raffle.soldTickets / raffle.totalTickets) * 100)
    : 0;
const drawDate = new Intl.DateTimeFormat("es-CO", {
  dateStyle: "medium",
}).format(new Date(primaryDrawAt));
const drawTime = new Intl.DateTimeFormat("es-CO", {
  timeStyle: "short",
}).format(new Date(primaryDrawAt));
const prizeCalendar = raffle.upcomingPrizeDraws.slice(0, 4);
const publicResults = raffle.completedPrizeDraws.slice(0, 6);
const activeDrawCount = Math.max(raffle.upcomingPrizeDraws.length, 1);
const calendarRows =
  prizeCalendar.length > 0
    ? prizeCalendar
    : featuredPrize
      ? [featuredPrize]
      : [];

const schema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: raffle.title,
  description: raffle.description,
  image: primaryImage,
  offers: {
    "@type": "Offer",
    priceCurrency: "COP",
    price: "2000",
    availability: "https://schema.org/InStock",
  },
};
---

<BaseLayout
  title="Rifaria | Campanas de rifas con premios por fecha"
  description="Compra una vez y participa en multiples premios. Rifaria publica calendario, numeros ganadores y compra segura en una sola landing."
  image={primaryImage}
  schema={schema}
>
  <div class="landing-page">
    <PublicHeader ctaHref="#comprar" ctaLabel="Comprar ahora" />

    <main>
      <section class="hero-shell container">
        <article class="hero-copy">
          <p class="section-kicker">Rifa activa</p>
          <h1 class="brand-title hero-headline">
            Ve el premio. Compra tus boletas.
          </h1>
          <p class="hero-subtitle">
            Una sola compra te deja participando por {activeDrawCount} premio
            {activeDrawCount === 1 ? "" : "s"} programado
            {activeDrawCount === 1 ? "" : "s"}. Pago local, boletas por correo y
            resultados publicos visibles para todos.
          </p>

          <div class="hero-actions">
            <a class="cta-btn" href="#comprar">Comprar boletas</a>
            <a
              class="pill pill-outline hero-secondary-action"
              href="#resultados"
            >
              Ver resultados
            </a>
          </div>

          <div class="hero-metrics">
            <article class="metric-card">
              <span class="metric-label">Boletas disponibles</span>
              <strong>{remainingTickets.toLocaleString("es-CO")}</strong>
              <p>Inventario visible.</p>
            </article>
            <article class="metric-card">
              <span class="metric-label">Premios activos</span>
              <strong>{activeDrawCount}</strong>
              <p>Una compra participa en todos.</p>
            </article>
            <article class="metric-card">
              <span class="metric-label">Siguiente sorteo</span>
              <strong>{drawDate}</strong>
              <p>{drawTime}</p>
            </article>
          </div>
        </article>

        <aside class="hero-visual glass-card">
          <div class="hero-visual-frame">
            <span class="hero-prize-chip">Premio principal</span>
            <img
              src={primaryImage}
              alt={`Premio destacado: ${primaryPrize}`}
              loading="eager"
              decoding="async"
              fetchpriority="high"
              width="1200"
              height="900"
              sizes="(max-width: 980px) 92vw, 58vw"
            />

            <div class="hero-image-panel">
              <div>
                <span class="hero-floating-label">Siguiente salida publica</span
                >
                <strong class="brand-title hero-floating-value"
                  >{primaryPrize}</strong
                >
              </div>

              <div class="hero-image-meta">
                <span>{drawDate}</span>
                <span>{drawTime}</span>
                <span>{primaryDrawSource}</span>
              </div>
            </div>
          </div>
        </aside>
      </section>

      <PurchaseWidget
        raffleTitle={raffle.title}
        eligiblePrizeCount={activeDrawCount}
        client:load
      />

      <section class="trust-strip container" aria-label="Ventajas principales">
        <span>PSE, tarjeta y Nequi</span>
        <span>Boletas por correo al confirmar pago</span>
        <span>{soldProgress}% vendido y resultados visibles</span>
      </section>

      <section class="section-shell container" id="premios">
        <div class="section-heading section-heading-compact">
          <p class="section-kicker">Fechas y premios</p>
          <h2 class="brand-title section-title">
            Todo el calendario en una vista rapida
          </h2>
          <p class="section-copy">
            Compras una vez y sigues activo en todas estas fechas.
          </p>
        </div>

        <div class="schedule-board glass-card">
          {
            calendarRows.map((draw, index) => (
              <article
                class={`schedule-row${draw.isMajorPrize ? " is-major" : ""}`}
              >
                <div class="schedule-row-index">
                  <span class="schedule-row-step">Corte 0{index + 1}</span>
                  <strong>
                    {new Intl.DateTimeFormat("es-CO", {
                      day: "2-digit",
                      month: "short",
                    }).format(new Date(draw.drawAt))}
                  </strong>
                </div>

                <div class="schedule-row-body">
                  <div class="schedule-row-top">
                    <span class="schedule-row-value">{draw.displayValue}</span>
                    {draw.isMajorPrize ? (
                      <span class="schedule-row-flag">Premio mayor</span>
                    ) : null}
                  </div>
                  <h3 class="brand-title schedule-row-title">{draw.title}</h3>
                  <p class="schedule-row-copy">{draw.description}</p>
                </div>

                <div class="schedule-row-meta">
                  <span>
                    {new Intl.DateTimeFormat("es-CO", {
                      dateStyle: "medium",
                      timeStyle: "short",
                    }).format(new Date(draw.drawAt))}
                  </span>
                  <span>{draw.drawSource}</span>
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section-shell container" id="resultados">
        <div class="section-heading section-heading-compact">
          <p class="section-kicker">Resultados publicos</p>
          <h2 class="brand-title section-title">Numeros ganadores visibles</h2>
          <p class="section-copy">
            Cada sorteo publicado queda abajo, sin esconder resultados.
          </p>
        </div>

        {
          publicResults.length > 0 ? (
            <div class="results-grid results-grid-compact" id="ganadores">
              {publicResults.map((draw) => (
                <article class="result-card glass-card">
                  <div class="result-top">
                    <span class="winner-badge">{draw.displayValue}</span>
                    <span
                      class={`result-status ${draw.winnerLabel ? "is-winner" : "is-empty"}`}
                    >
                      {draw.winnerLabel ? "Ganador" : "Publicado"}
                    </span>
                  </div>
                  <h3 class="brand-title">{draw.title}</h3>
                  <strong class="brand-title result-number">
                    {draw.winningNumber ?? "Pendiente"}
                  </strong>
                  <div class="result-meta">
                    <span>
                      {new Intl.DateTimeFormat("es-CO", {
                        dateStyle: "medium",
                      }).format(new Date(draw.drawAt))}
                    </span>
                    <span>{draw.drawSource}</span>
                  </div>
                  <div class="result-meta">
                    <span>
                      {draw.winnerLabel ??
                        "Resultado publicado sin boleta pagada ganadora"}
                    </span>
                    {draw.proofUrl ? (
                      <a href={draw.proofUrl}>Ver prueba</a>
                    ) : null}
                  </div>
                </article>
              ))}
            </div>
          ) : (
            <article class="result-empty glass-card" id="ganadores">
              <span class="section-kicker">Aun no hay sorteos cerrados</span>
              <h3 class="brand-title">
                Los resultados publicados apareceran aqui
              </h3>
              <p>
                Apenas se cierre el primer premio, el numero ganador quedara
                visible para todos en este bloque.
              </p>
            </article>
          )
        }
      </section>
    </main>

    <PublicFooter />
  </div>
</BaseLayout>
