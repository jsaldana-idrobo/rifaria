---
const year = new Date().getFullYear();
---

<footer class="public-footer">
  <div class="container footer-grid">
    <section class="footer-brand">
      <strong class="brand-title">RIFARIA</strong>
      <p>
        Plataforma visual para rifas online con premios grandes, checkout local
        y trazabilidad operativa lista para lanzar.
      </p>
    </section>

    <section class="footer-column">
      <span class="footer-label">Explora</span>
      <div class="footer-links">
        <a href="/#premios">Premios</a>
        <a href="/#ganadores">Ganadores</a>
        <a href="/#comprar">Comprar</a>
      </div>
    </section>

    <section class="footer-column">
      <span class="footer-label">Legal</span>
      <div class="footer-links">
        <a href="/terminos">Terminos</a>
        <a href="/politica-datos">Politica de datos</a>
        <a href="/admin">Admin</a>
      </div>
    </section>

    <section class="footer-column">
      <span class="footer-label">Confianza</span>
      <p class="footer-note">
        Pagos por tarjeta, PSE y Nequi, soporte operativo y reglas visibles para
        cada rifa.
      </p>
    </section>
  </div>

  <div class="container footer-legal">
    <span>Rifaria {year}</span>
    <span
      >Diseno comercial balanceado para lanzamiento de rifas en Colombia.</span
    >
  </div>
</footer>
