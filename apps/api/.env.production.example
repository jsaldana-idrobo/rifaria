NODE_ENV=production
PORT=4000
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
JWT_ACCESS_SECRET=<strong-random-access-secret>
JWT_REFRESH_SECRET=<strong-random-refresh-secret>
WOMPI_ENV=production
WOMPI_PUBLIC_KEY=<wompi-public-key>
WOMPI_PRIVATE_KEY=<wompi-private-key>
WOMPI_INTEGRITY_SECRET=<wompi-integrity-secret>
WOMPI_EVENTS_SECRET=<wompi-events-secret>
WEB_BASE_URL=https://<your-domain>
REDIS_HOST=<redis-host>
REDIS_PORT=6379
REDIS_PASSWORD=<redis-password-if-needed>
NOTIFICATIONS_MODE=inline
EMAIL_PROVIDER=resend
# Use a verified sender domain in your email provider. Do not use .local or placeholders here.
EMAIL_FROM=Rifaria <no-reply@<your-domain>>
EMAIL_REPLY_TO=soporte@<your-domain>
RESEND_API_KEY=
POSTMARK_SERVER_TOKEN=
POSTMARK_MESSAGE_STREAM=outbound
MAINTENANCE_TOKEN=<strong-random-maintenance-token>
